 <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
        }
        input {
            display: block;
            margin: 10px 0;
            padding: 5px;
        }
    </style>
</head>
<body>
    
    <h2>Edit Student Registration</h2>
    <form action="/student/update/<%= student.id %>" method="POST">
            <input type="text"  name="name" value="<%= student.name %>"  placeholder="enter name">
            <input type="text" name="email" value="<%= student.email %>" placeholder="enter email">
            <input type="text" name="mobile" value="<%= student.mobile %>"  placeholder="enter mobile">
            <input type="submit" value="submit">
        </form>

</body>
</html>