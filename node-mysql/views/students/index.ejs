<% if(message){ %>
    <p style="color: green;"><%= message %></p>
<% } %>

<h2>Students</h2>

<a href="/students/create">Add Student</a>

<table border="1">

    <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Email</th>
        <th>Mobile</th>
        <th>Action</th>
    </tr>

    <% students.forEach(function(e){ %>

        <tr>
            <td> <%= e.id %> </td>
            <td> <%= e.name %> </td>
            <td> <%= e.email %> </td>
            <td> <%= e.mobile %>  </td>
            <td>
                <a href="/student/edit/<%= e.id %>">EDIT</a>
                <a href="/student/delete/<%= e.id %>">Delete</a>
            </td>
        </tr>

    <% })%>

</table>